# LLM providers
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=deepseek-ai/DeepSeek-V4-Flash

AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1/chat/completions
# gemma4 smarter and cheaper than gemini 3.1 flash
AIM_MODEL=google/gemma-4-31b-it

# Band (optional overrides; primary config in config/agent_config.yaml)
BAND_ROOM_ID=

# RAG
CHROMA_PERSIST_DIR=./data/chroma

# HERALD outputs
N8N_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# App
LOG_LEVEL=INFO
